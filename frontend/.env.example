# URL of the model API (the free Hugging Face Space). Server-side only — never
# exposed to the browser (the /api/analyze route proxies to it).
# Local dev against a locally-running API:
MODEL_API_URL=http://localhost:8000
# Production (set this in the Vercel project's Environment Variables instead):
# MODEL_API_URL=https://<your-username>-nlp-pipeline-api.hf.space
