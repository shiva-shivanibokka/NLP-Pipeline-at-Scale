# ── Infrastructure ────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns

# ── Model ─────────────────────────────────────────────────────────────────────
# Training strategy: independent | hard_sharing | uncertainty_weighted
TRAINING_STRATEGY=uncertainty_weighted
AGENT_MAX_TURNS=50

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
